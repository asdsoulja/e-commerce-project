    {
      "name": "11 Admin Users",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/admin/users"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Admin users responds 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var responseData = pm.response.json();",
              "pm.expect(Array.isArray(responseData.users)).to.eql(true);",
              "pm.expect(responseData.users.length).to.be.above(0);",
              "(responseData.users || []).forEach((user) => {",
              "  if (user.paymentProfile) {",
              "    pm.expect(user.paymentProfile).to.not.have.property('cardHolder');",
              "    pm.expect(user.paymentProfile).to.not.have.property('expiryMonth');",
              "    pm.expect(user.paymentProfile).to.not.have.property('expiryYear');",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
