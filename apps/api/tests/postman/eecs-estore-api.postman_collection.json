{
  "info": {
    "_postman_id": "7c8e36bd-2a71-4d1f-a71f-d816f797f7b9",
    "name": "EECS E-Store Backend API Smoke Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Health responds 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var responseData = pm.response.json();",
              "pm.expect(responseData.status).to.eql('ok');"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 Catalog Items",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/catalog/items"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Catalog responds 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var responseData = pm.response.json();",
              "pm.expect(Array.isArray(responseData.items)).to.eql(true);",
              "pm.expect(responseData.items.length).to.be.above(0);",
              "pm.collectionVariables.set('itemId', responseData.items[0].id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 Guest Add to Cart",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"itemId\": \"{{itemId}}\",\n  \"quantity\": 1\n}"
        },
        "url": "{{baseUrl}}/cart/items"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Guest cart add responds 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "var responseData = pm.response.json();",
              "pm.expect(responseData.cart).to.exist;"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "04 Register Customer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Postman\",\n  \"lastName\": \"Tester\",\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"Customer123!\",\n  \"phone\": \"4165552000\",\n  \"shippingAddress\": {\n    \"street\": \"201 Postman Street\",\n    \"province\": \"Ontario\",\n    \"country\": \"Canada\",\n    \"zip\": \"M2M2M2\",\n    \"phone\": \"4165552000\"\n  },\n  \"billingAddress\": {\n    \"street\": \"201 Postman Street\",\n    \"province\": \"Ontario\",\n    \"country\": \"Canada\",\n    \"zip\": \"M2M2M2\",\n    \"phone\": \"4165552000\"\n  },\n  \"creditCard\": {\n    \"cardHolder\": \"Postman Tester\",\n    \"cardNumber\": \"4111 1111 1111 1111\",\n    \"expiryMonth\": \"12\",\n    \"expiryYear\": \"2030\",\n    \"cvv\": \"123\"\n  }\n}"
        },
        "url": "{{baseUrl}}/identity/register"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const randomEmail = `postman.qa.${Date.now()}@example.local`;",
              "pm.collectionVariables.set('customerEmail', randomEmail);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Register responds 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "var responseData = pm.response.json();",
              "pm.expect(responseData.user).to.exist;"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "05 Me (Customer)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/identity/me"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Me responds 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var responseData = pm.response.json();",
              "pm.expect((responseData.user || {}).email).to.eql(pm.collectionVariables.get('customerEmail'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
