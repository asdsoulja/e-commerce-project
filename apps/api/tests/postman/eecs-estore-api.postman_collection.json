            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "07 Checkout (Saved Payment)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"shippingAddress\": {\n    \"street\": \"201 Postman Street\",\n    \"province\": \"Ontario\",\n    \"country\": \"Canada\",\n    \"zip\": \"M2M2M2\",\n    \"phone\": \"4165552001\"\n  },\n  \"billingAddress\": {\n    \"street\": \"201 Postman Street\",\n    \"province\": \"Ontario\",\n    \"country\": \"Canada\",\n    \"zip\": \"M2M2M2\",\n    \"phone\": \"4165552001\"\n  },\n  \"creditCard\": {\n    \"cardHolder\": \"Postman Tester\",\n    \"expiryMonth\": \"12\",\n    \"expiryYear\": \"2030\",\n    \"cvv\": \"123\"\n  },\n  \"useSavedPayment\": true,\n  \"saveAsDefault\": true\n}"
        },
        "url": "{{baseUrl}}/orders/checkout"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Checkout responds 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var responseData = pm.response.json();",
              "pm.expect(typeof responseData.approved).to.eql('boolean');"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
